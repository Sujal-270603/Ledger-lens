{
  "name": "gst-ai-invoice-processor",
  "version": "1.0.0",
  "description": "Enterprise GST ID Processing Backend",
  "main": "dist/server.js",
  "scripts": {
    "seed": "ts-node prisma/seed.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "jest",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run workers\""
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/client-sqs": "^3.1000.0",
    "@aws-sdk/client-textract": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.983.0",
    "@fastify/autoload": "^5.8.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/sensible": "^5.5.0",
    "@fastify/swagger": "^8.12.0",
    "@fastify/swagger-ui": "^1.10.1",
    "@google/genai": "^1.45.0",
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.15.0",
    "dotenv": "^16.3.1",
    "envalid": "^8.0.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.24.3",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^1.1.9",
    "ioredis": "^5.9.3",
    "js2xmlparser": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.20.1",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "razorpay": "^2.9.2",
    "uuid": "^9.0.1",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.1.0",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
